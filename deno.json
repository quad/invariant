{
  "name": "@quad/invariant",
  "version": "0.1.1",
  "exports": "./src/invariant.ts",
  "publish": {
    "exclude": [
      "*.test.ts"
    ],
    "include": [
      "LICENSE",
      "PRIOR_ART.md",
      "README.md",
      "src/"
    ]
  },
  "tasks": {
    "cd": "deno task ci && deno task publish:jsr",
    "ci:fix": "deno fmt && deno lint --fix",
    "ci:test": "deno check && deno test",
    "ci": "deno task ci:fix && deno task ci::test",
    "dev": "deno test --watch",
    "publish:jsr": "deno publish"
  },
  "license": "Apache-2.0",
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  }
}
